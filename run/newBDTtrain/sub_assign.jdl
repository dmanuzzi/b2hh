executable            = run_assign.sh
getenv                = true
request_memory        = 48GB
output                = ../../log/newBDTtrain/out/assign_$(c)_$(y)_$(p).txt
error                 = ../../log/newBDTtrain/err/assign_$(c)_$(y)_$(p).txt
log                   = ../../log/newBDTtrain/log/assign_newBDTtrain_forNorm.txt
arguments             = $(c) $(y) $(p)
JobBatchName          = assignBDT_forNorm
stream_output         = True
queue c, y, p from jobs_assign.txt