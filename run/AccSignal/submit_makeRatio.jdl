executable            = run_makeRatio.sh
getenv                = true
request_memory        = 4G
output                = ../../log/AccSignal/out/makeRatio_$(c)_$(b)_$(y)_$(m)_$(n)_$(f)_$(d)_$(t).txt
error                 = ../../log/AccSignal/err/makeRatio_$(c)_$(b)_$(y)_$(m)_$(n)_$(f)_$(d)_$(t).txt
log                   = ../../log/AccSignal/log/AccSignal_makeRatio.txt
arguments             = $(c) $(b) $(y) $(m) $(n) $(f) $(d) $(t)
JobBatchName          = AccSignal_makeRatio
queue c, b, y, m, n, f, d, t from jobs_makeRatio.txt