executable            = run.sh
getenv                = true
Requirements = (machine == "lhcb-256g-96ht-a.cr.cnaf.infn.it")
output                = ../../log/AccSignal/out/$(n)_$(b)_$(y)_$(m).txt
error                 = ../../log/AccSignal/err/$(n)_$(b)_$(y)_$(m).txt
log                   = ../../log/AccSignal/log/AccSignal.txt
arguments             = $(n) $(b) $(y) $(m)
JobBatchName          = AccSignal
queue n, b, y, m from jobs.txt