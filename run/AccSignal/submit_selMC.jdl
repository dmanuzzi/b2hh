executable            = run_selMC.sh
getenv                = true
#Requirements = (machine == "lhcb-256g-96ht-a.cr.cnaf.infn.it")
output                = ../../log/AccSignal/out/selMC_$(n)_$(b)_$(y)_$(m)_$(d)_$(f).txt
error                 = ../../log/AccSignal/err/selMC_$(n)_$(b)_$(y)_$(m)_$(d)_$(f).txt
log                   = ../../log/AccSignal/log/AccSignal_selMC.txt
arguments             = $(n) $(b) $(y) $(m) $(d) $(f) $(c)
JobBatchName          = AccSignal_selMC
queue n, b, y, m, d, f, c from jobs_selMC.txt