executable            = run_fitAcc.sh
getenv                = true
request_memory        = 4G
output                = ../../log/AccSignal/out/4fitAcc_$(c)_$(b)_$(y)_$(m)_$(n)_$(f)_$(d)_$(t).txt
error                 = ../../log/AccSignal/err/4fitAcc_$(c)_$(b)_$(y)_$(m)_$(n)_$(f)_$(d)_$(t).txt
log                   = ../../log/AccSignal/log/4AccSignal_fitAcc.txt
arguments             = $(c) $(b) $(y) $(m) $(n) $(f) $(d) $(t)
JobBatchName          = AccSignal_fitAcc
queue c, b, y, m, n, f, d, t from jobs_fitAcc.txt