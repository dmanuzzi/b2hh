executable            = run_subtractBkg.sh
getenv                = true
request_memory        = 4G
output                = ../../log/AccSignal/out/3subtractBkg_$(n)_$(b)_$(y)_$(m).txt
error                 = ../../log/AccSignal/err/3subtractBkg_$(n)_$(b)_$(y)_$(m).txt
log                   = ../../log/AccSignal/log/3AccSignal_subtractBkg.txt
arguments             = $(n) $(b) $(y) $(m) 
JobBatchName          = AccSignal_subtractBkg
queue n, b, y, m from jobs_subtractBkg.txt