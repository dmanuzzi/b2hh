executable            = run_kineWeight.sh
getenv                = true
request_memory        = 4G
output                = ../../log/AccSignal/out/2kineWeight_$(n)_$(b)_$(y)_$(m)_$(d)_$(f).txt
error                 = ../../log/AccSignal/err/2kineWeight_$(n)_$(b)_$(y)_$(m)_$(d)_$(f).txt
log                   = ../../log/AccSignal/log/2AccSignal_kineWeight.txt
arguments             = $(n) $(b) $(y) $(m) $(d) $(f) $(BB) $(dd) $(ff)
JobBatchName          = AccSignal_kineWeight
queue n, b, y, m, d, f,  BB, dd, ff from jobs_kineWeight.txt