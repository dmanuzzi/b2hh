executable            = run_kineWeight.sh
getenv                = true
request_memory        = 4G
#Requirements = (machine == "lhcb-256g-96ht-a.cr.cnaf.infn.it")
output                = ../../log/AccSignal/out/kineWeight_$(n)_$(b)_$(y)_$(m)_$(d)_$(f).txt
error                 = ../../log/AccSignal/err/kineWeight_$(n)_$(b)_$(y)_$(m)_$(d)_$(f).txt
log                   = ../../log/AccSignal/log/AccSignal_kineWeight.txt
arguments             = $(n) $(b) $(y) $(m) $(d) $(f) $(BB) $(dd) $(ff)
JobBatchName          = AccSignal_kineWeight
queue n, b, y, m, d, f,  BB, dd, ff from jobs_kineWeight.txt