executable = ./runPlots.sh
JobBatchName = "FitTotalPlots"
arguments  = $(taggers) $(bdtName) $(bdtCut) $(year) $(magnet) $(splitConf) $(outDir) $(Ncpu) $(var) $(massRange) $(finalState) $(btag) $(ftag) $(tagger)
request_cpus = $(Ncpu)
request_memory = 16GB
universe = vanilla
getenv = True
output = ../../log/FitTotal/plots/out/out_$(var)_$(massRange)_$(finalState)_$(btag)_$(ftag)_$(tagger).txt
error  = ../../log/FitTotal/plots/err/err_$(var)_$(massRange)_$(finalState)_$(btag)_$(ftag)_$(tagger).txt
log    = ../../log/FitTotal/plots/log/log_$(var)_$(massRange)_$(finalState)_$(btag)_$(ftag)_$(tagger).txt
queue taggers, bdtName, bdtCut, year, magnet, splitConf, outDir, Ncpu, var, massRange, finalState, btag, ftag, tagger from jobsPlots.txt
