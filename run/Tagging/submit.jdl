executable            = run.sh
getenv                = true
output                = ../../log/Tagging/out/$(n)_$(b)_$(y)_$(m).txt
error                 = ../../log/Tagging/err/$(n)_$(b)_$(y)_$(m).txt
log                   = ../../log/Tagging/log/Tagging.txt
arguments             = $(n) $(b) $(y) $(m) $(kpi) $(pipi) $(kk) $(pik)
JobBatchName          = Tagging
queue n, b, y, m, kpi, pik, pipi, kk  from jobs.txt