executable   = run.sh
JobBatchName = MassFit_NewBDT
arguments    = $(taggers) $(bdtName) $(bdtCut) $(year) $(mag) $(splitConf) $(outDir) $(Ncpus)
Request_cpus = $(Ncpus)
request_memory = 32GB
universe     = vanilla
getenv       = True
output       = ../../log/MassFit/out/$(outDir).txt
error        = ../../log/MassFit/err/$(outDir).txt
log          = ../../log/MassFit/log/MassFit.txt
queue taggers, bdtName, bdtCut, year, mag, splitConf, outDir, Ncpus from jobs.txt