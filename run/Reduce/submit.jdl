executable   = run.sh
JobBatchName = "Reduce"
arguments    = $(n) $(b) $(y) $(m) $(p)
universe     = vanilla
getenv       = True
request_memory = 16G
output       = ../../log/Reduce/out/$(n)_$(b)_$(y)_$(m)_$(p).txt
error        = ../../log/Reduce/err/$(n)_$(b)_$(y)_$(m)_$(p).txt
log          = ../../log/Reduce/log/Reduce.txt
queue n, b, y, m, p from jobs.txt
