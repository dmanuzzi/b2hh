executable   = run.sh
JobBatchName = "Data"
arguments    = $(d) $(y) $(m) $(c) $(i) $(f)
universe     = vanilla
getenv       = True
Requirements =  (machine == "lhcb-256g-96ht-a.cr.cnaf.infn.it")
output       = ../../log/Data/out/$(d)_$(y)_$(m)_$(i).txt
error        = ../../log/Data/err/$(d)_$(y)_$(m)_$(i).txt
log          = ../../log/Data/log/Data_$(c).txt
queue d, y, m, c, i, f from jobs.txt
