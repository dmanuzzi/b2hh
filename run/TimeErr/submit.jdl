executable            = run.sh
getenv                = true
output                = ../../log/TimeErr/out/$(n)_$(b)_$(y)_$(m)_$(f).txt
error                 = ../../log/TimeErr/err/$(n)_$(b)_$(y)_$(m)_$(f).txt
log                   = ../../log/TimeErr/log/TimeErr.txt
arguments             = $(n) $(b) $(y) $(m) $(f)
JobBatchName          = TimeErr
queue n, b, y, m, f  from jobs.txt